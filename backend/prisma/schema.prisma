// SkillQuest — Prisma Schema (SQLite — local dev)
// Production uses prisma/schema.postgresql.prisma (see DEPLOYMENT.md)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String
  passwordHash  String
  avatar        String?
  bio           String?

  level         Int       @default(1)
  xp            Int       @default(0)
  xpToNextLevel Int       @default(100)
  streak        Int       @default(0)
  longestStreak Int       @default(0)
  lastActiveAt  DateTime?

  isPremium        Boolean   @default(false)
  premiumUntil     DateTime?
  stripeCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress           Progress[]
  xpLogs             XPLog[]
  userAchievements   UserAchievement[]
  dailyChallenges    DailyChallenge[]
  generatedContents  GeneratedContent[]

  @@map("users")
}

model Skill {
  id           String  @id @default(cuid())
  name         String
  description  String
  icon         String
  category     String
  color        String
  difficulty   Int     @default(1)
  positionX    Float   @default(0)
  positionY    Float   @default(0)
  // SQLite doesn't support array columns — store as JSON string
  prerequisites String  @default("[]")
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  lessons  Lesson[]
  progress Progress[]

  @@map("skills")
}

model Lesson {
  id          String  @id @default(cuid())
  skillId     String
  title       String
  description String
  xpReward    Int     @default(10)
  order       Int
  type        String
  difficulty  Int     @default(1)
  duration    Int     @default(5)
  // JSON string — quiz questions, paragraphs, code blocks
  content     String  @default("[]")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  skill    Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  progress Progress[]

  @@map("lessons")
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  skillId     String?
  lessonId    String?
  status      String   @default("not_started")
  score       Int?
  attempts    Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill  Skill?  @relation(fields: [skillId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("progress")
}

model XPLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  // JSON string for metadata
  meta      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("xp_logs")
}

model Achievement {
  id          String @id @default(cuid())
  name        String
  description String
  icon        String
  xpReward    Int    @default(0)
  rarity      String @default("common")
  // JSON string: { "type": "lessons_completed", "threshold": 10 }
  condition   String
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model DailyChallenge {
  id          String   @id @default(cuid())
  userId      String
  date        String   // stored as "YYYY-MM-DD" string (SQLite has no Date type)
  task        String
  xpReward    Int
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_challenges")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI-Generated Content
// SQLite  → notes / mcqs stored as JSON strings  (String columns)
// PostgreSQL → swap String → Json for native jsonb storage
// ─────────────────────────────────────────────────────────────────────────────
model GeneratedContent {
  id        String   @id @default(cuid())
  topic     String
  // JSON string: { summary, sections[], glossary[], resources[] }
  notes     String
  // JSON string: MCQ[]  { question, options[], answer, explanation }
  mcqs      String
  model     String   @default("gpt-4o-mini")
  // Optional — null when called without auth
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("generated_content")
}
